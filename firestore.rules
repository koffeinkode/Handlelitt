rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global items - alle kan lese
    match /globalItems/{item} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Global categories - alle kan lese
    match /globalCategories/{category} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Pending approvals - autentiserte brukere kan skrive
    match /pendingApprovals/{approval} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Metadata - alle kan lese, autentiserte kan skrive
    match /metadata/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Shared lists - alle kan lese, autentiserte kan opprette/endre, kun eier kan slette
    match /sharedLists/{list} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }
  }
}
